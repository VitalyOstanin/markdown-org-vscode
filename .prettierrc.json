{
  "tabWidth": 4,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 120,
  "endOfLine": "lf",
  "embeddedLanguageFormatting": "off",
  "overrides": [
    {
      "files": ["*.yml", "*.yaml", "*.json"],
      "options": { "tabWidth": 2 }
    }
  ]
}
