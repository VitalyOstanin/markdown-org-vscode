{
  "name": "markdown-org-vscode",
  "displayName": "Markdown Org",
  "description": "Org-mode style task management in Markdown: TODO/DONE workflow, priorities, SCHEDULED/DEADLINE timestamps, agenda views, and CLOCK time tracking.",
  "version": "0.7.0",
  "publisher": "vitalyostanin",
  "repository": {
    "type": "git",
    "url": "https://github.com/VitalyOstanin/markdown-org-vscode"
  },
  "homepage": "https://github.com/VitalyOstanin/markdown-org-vscode#readme",
  "bugs": {
    "url": "https://github.com/VitalyOstanin/markdown-org-vscode/issues"
  },
  "qna": false,
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#272822",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=22"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "agenda",
    "clock",
    "clocktable",
    "deadline",
    "gtd",
    "markdown",
    "org",
    "org-mode",
    "planning",
    "productivity",
    "scheduled",
    "task management",
    "tasks",
    "time tracking",
    "todo"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "In an untrusted workspace, configured executable paths (e.g. markdown-org.extractorPath) and file paths (markdown-org.maintainFilePath) are not used."
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "markdown-org.setTodo",
        "title": "Set TODO",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.setDone",
        "title": "Set DONE",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.togglePriority",
        "title": "Toggle Priority",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.insertCreated",
        "title": "Insert CREATED Timestamp",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.insertScheduled",
        "title": "Insert SCHEDULED Timestamp",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.insertDeadline",
        "title": "Insert DEADLINE Timestamp",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.insertClockStart",
        "title": "Insert CLOCK Start",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.insertClockFinish",
        "title": "Insert CLOCK Finish",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.insertClockTable",
        "title": "Insert CLOCK Table",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.showAgendaDay",
        "title": "Show Agenda (Day)",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.showAgendaWeek",
        "title": "Show Agenda (Week)",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.showAgendaMonth",
        "title": "Show Agenda (Month)",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.showTasks",
        "title": "Show Tasks",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.timestampUp",
        "title": "Timestamp Up",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.timestampDown",
        "title": "Timestamp Down",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.toggleTimestampActive",
        "title": "Toggle Timestamp Active/Inactive",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.moveToArchive",
        "title": "Move to Archive",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.promoteToMaintain",
        "title": "Promote to Maintain",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.cycleTag",
        "title": "Cycle Tag Filter",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.gcalSync.connect",
        "title": "Connect Google Calendar",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.gcalSync.disconnect",
        "title": "Disconnect Google Calendar",
        "category": "Markdown Org"
      },
      {
        "command": "markdown-org.gcalSync.selectCalendar",
        "title": "Select Google Calendar",
        "category": "Markdown Org"
      }
    ],
    "keybindings": [
      {
        "command": "markdown-org.setTodo",
        "key": "ctrl+k ctrl+t",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.setDone",
        "key": "ctrl+k ctrl+d",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.togglePriority",
        "key": "ctrl+k ctrl+p",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertCreated",
        "key": "ctrl+k ctrl+k ctrl+c",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertScheduled",
        "key": "ctrl+k ctrl+k ctrl+s",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertDeadline",
        "key": "ctrl+k ctrl+k ctrl+d",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertClockStart",
        "key": "ctrl+k ctrl+c ctrl+s",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertClockFinish",
        "key": "ctrl+k ctrl+c ctrl+f",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertClockTable",
        "key": "ctrl+k ctrl+c ctrl+v",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.showAgendaWeek",
        "key": "ctrl+k ctrl+w",
        "when": "(editorTextFocus && editorLangId == markdown) || markdown-org.agendaFocused"
      },
      {
        "command": "markdown-org.showAgendaMonth",
        "key": "ctrl+k ctrl+m",
        "when": "(editorTextFocus && editorLangId == markdown) || markdown-org.agendaFocused"
      },
      {
        "command": "markdown-org.timestampUp",
        "key": "shift+up",
        "when": "editorTextFocus && editorLangId == markdown && markdown-org.timestampAdjustable"
      },
      {
        "command": "markdown-org.timestampDown",
        "key": "shift+down",
        "when": "editorTextFocus && editorLangId == markdown && markdown-org.timestampAdjustable"
      },
      {
        "command": "markdown-org.moveToArchive",
        "key": "ctrl+k ctrl+k ctrl+m ctrl+a",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.promoteToMaintain",
        "key": "ctrl+k ctrl+k ctrl+m ctrl+p",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.cycleTag",
        "key": "ctrl+k ctrl+k ctrl+t"
      }
    ],
    "configuration": {
      "title": "Markdown Org",
      "properties": {
        "markdown-org.extractorPath": {
          "type": "string",
          "default": "",
          "description": "Path to markdown-org-extract executable. Empty (default) uses the bundled binary, falling back to PATH. Set to override (e.g. an absolute path for local builds)."
        },
        "markdown-org.workspaceDir": {
          "type": "string",
          "default": "",
          "description": "Directory to scan for markdown files (empty = workspace root)"
        },
        "markdown-org.maintainFilePath": {
          "type": "string",
          "default": "",
          "description": "Path to maintain file for promoted headings (empty = disabled)"
        },
        "markdown-org.dateLocale": {
          "type": "string",
          "default": "en-US",
          "description": "Locale for date formatting (e.g., en-US, ru-RU, de-DE)"
        },
        "markdown-org.firstDayOfWeek": {
          "type": "string",
          "enum": [
            "monday",
            "sunday",
            "auto"
          ],
          "default": "monday",
          "description": "First day of week in month calendar. 'auto' uses locale's default via Intl.Locale.weekInfo (falls back to monday if unsupported)."
        },
        "markdown-org.fileTags": {
          "type": "array",
          "default": [
            {
              "name": "ALL",
              "pattern": ""
            },
            {
              "name": "WORK",
              "pattern": "work"
            },
            {
              "name": "PRIVATE",
              "pattern": "!work"
            }
          ],
          "description": "File tags. Pattern is matched (substring) against the file's basename. Empty pattern disables the filter (show all). '!'-prefix means 'not matching any positive pattern' — the text after '!' is ignored."
        },
        "markdown-org.currentTag": {
          "type": "string",
          "default": "ALL",
          "description": "Currently selected tag filter for agenda view. Stored per workspace when a workspace is open."
        },
        "markdown-org.clockRoundMinutes": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 60,
          "description": "Round CLOCK timestamps to N minutes (e.g., 15, 30). 0 disables rounding. Negative and out-of-range values are also treated as 'no rounding'."
        },
        "markdown-org.weekdayLocale": {
          "type": "string",
          "enum": [
            "ru",
            "en"
          ],
          "default": "ru",
          "description": "Language for the weekday short name inserted into timestamps (CREATED/SCHEDULED/DEADLINE/CLOCK). 'ru' produces Пн/Вт/..., 'en' produces Mon/Tue/...."
        },
        "markdown-org.gcalSync.clientId": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Google OAuth Desktop client_id for Calendar sync (BYO). The client_secret is entered on connect and stored in the OS keychain, not here."
        },
        "markdown-org.gcalSync.calendarName": {
          "type": "string",
          "default": "markdown-org",
          "description": "Name used to find-or-create the sync calendar when no calendarId is pinned."
        },
        "markdown-org.gcalSync.calendarId": {
          "type": "string",
          "default": "",
          "description": "Pinned Google calendar id for sync (takes precedence over calendarName). Usually set by the Select Google Calendar command."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && mocha --config .mocharc.unit.json",
    "test:watch": "npm run compile && node ./scripts/test-watch.js",
    "test:coverage": "npm run compile && c8 mocha --config .mocharc.unit.json",
    "test:integration": "npm run compile && node ./scripts/run-integration-tests.js",
    "test:integration:coverage": "npm run compile && node ./scripts/run-integration-tests.js --coverage --coverage-output=./coverage/integration",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "vsce package",
    "prepare": "husky"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.5",
    "qs": "^6.15.2"
  },
  "x-markdown-org": {
    "extractorVersion": "0.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^28.0.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "c8": "^11.0.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.6",
    "prettier": "^3.8.3",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
