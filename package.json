{
  "name": "markdown-org-vscode",
  "displayName": "Markdown Org",
  "description": "Org-style task management for Markdown files",
  "version": "0.4.0",
  "publisher": "vitalyostanin",
  "repository": {
    "type": "git",
    "url": "https://github.com/VitalyOstanin/markdown-org-vscode"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=20"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "In an untrusted workspace, configured executable paths (e.g. markdown-org.extractorPath) and file paths (markdown-org.maintainFilePath) are not used."
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "markdown-org.setTodo",
        "title": "Markdown Org: Set TODO"
      },
      {
        "command": "markdown-org.setDone",
        "title": "Markdown Org: Set DONE"
      },
      {
        "command": "markdown-org.togglePriority",
        "title": "Markdown Org: Toggle Priority"
      },
      {
        "command": "markdown-org.insertCreated",
        "title": "Markdown Org: Insert CREATED Timestamp"
      },
      {
        "command": "markdown-org.insertScheduled",
        "title": "Markdown Org: Insert SCHEDULED Timestamp"
      },
      {
        "command": "markdown-org.insertDeadline",
        "title": "Markdown Org: Insert DEADLINE Timestamp"
      },
      {
        "command": "markdown-org.insertClockStart",
        "title": "Markdown Org: Insert CLOCK Start"
      },
      {
        "command": "markdown-org.insertClockFinish",
        "title": "Markdown Org: Insert CLOCK Finish"
      },
      {
        "command": "markdown-org.insertClockTable",
        "title": "Markdown Org: Insert CLOCK Table"
      },
      {
        "command": "markdown-org.showAgendaDay",
        "title": "Markdown Org: Show Agenda (Day)"
      },
      {
        "command": "markdown-org.showAgendaWeek",
        "title": "Markdown Org: Show Agenda (Week)"
      },
      {
        "command": "markdown-org.showAgendaMonth",
        "title": "Markdown Org: Show Agenda (Month)"
      },
      {
        "command": "markdown-org.showTasks",
        "title": "Markdown Org: Show Tasks"
      },
      {
        "command": "markdown-org.timestampUp",
        "title": "Markdown Org: Timestamp Up"
      },
      {
        "command": "markdown-org.timestampDown",
        "title": "Markdown Org: Timestamp Down"
      },
      {
        "command": "markdown-org.moveToArchive",
        "title": "Markdown Org: Move to Archive"
      },
      {
        "command": "markdown-org.promoteToMaintain",
        "title": "Markdown Org: Promote to Maintain"
      },
      {
        "command": "markdown-org.cycleTag",
        "title": "Markdown Org: Cycle Tag Filter"
      }
    ],
    "keybindings": [
      {
        "command": "markdown-org.setTodo",
        "key": "ctrl+k ctrl+t",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.setDone",
        "key": "ctrl+k ctrl+d",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.togglePriority",
        "key": "ctrl+k ctrl+p",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertCreated",
        "key": "ctrl+k ctrl+k ctrl+c",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertScheduled",
        "key": "ctrl+k ctrl+k ctrl+s",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertDeadline",
        "key": "ctrl+k ctrl+k d",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertClockStart",
        "key": "ctrl+k ctrl+k ctrl+c ctrl+s",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertClockFinish",
        "key": "ctrl+k ctrl+k ctrl+c ctrl+f",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.insertClockTable",
        "key": "ctrl+k ctrl+k ctrl+c ctrl+v",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.showAgendaWeek",
        "key": "ctrl+k ctrl+w",
        "when": "(editorTextFocus && editorLangId == markdown) || markdown-org.agendaFocused"
      },
      {
        "command": "markdown-org.showAgendaMonth",
        "key": "ctrl+k ctrl+m",
        "when": "(editorTextFocus && editorLangId == markdown) || markdown-org.agendaFocused"
      },
      {
        "command": "markdown-org.timestampUp",
        "key": "shift+up",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.timestampDown",
        "key": "shift+down",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.moveToArchive",
        "key": "ctrl+k ctrl+k ctrl+m ctrl+a",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.promoteToMaintain",
        "key": "ctrl+k ctrl+k ctrl+m ctrl+p",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdown-org.cycleTag",
        "key": "ctrl+k ctrl+k ctrl+t"
      }
    ],
    "configuration": {
      "title": "Markdown Org",
      "properties": {
        "markdown-org.extractorPath": {
          "type": "string",
          "default": "markdown-org-extract",
          "description": "Path to markdown-org-extract executable (default: searches in PATH)"
        },
        "markdown-org.workspaceDir": {
          "type": "string",
          "default": "",
          "description": "Directory to scan for markdown files (empty = workspace root)"
        },
        "markdown-org.maintainFilePath": {
          "type": "string",
          "default": "",
          "description": "Path to maintain file for promoted headings (empty = disabled)"
        },
        "markdown-org.dateLocale": {
          "type": "string",
          "default": "en-US",
          "description": "Locale for date formatting (e.g., en-US, ru-RU, de-DE)"
        },
        "markdown-org.firstDayOfWeek": {
          "type": "string",
          "enum": [
            "monday",
            "sunday",
            "auto"
          ],
          "default": "monday",
          "description": "First day of week in month calendar. 'auto' uses locale's default via Intl.Locale.weekInfo (falls back to monday if unsupported)."
        },
        "markdown-org.fileTags": {
          "type": "array",
          "default": [
            {
              "name": "ALL",
              "pattern": ""
            },
            {
              "name": "WORK",
              "pattern": "work"
            },
            {
              "name": "PRIVATE",
              "pattern": "!work"
            }
          ],
          "description": "File tags. Pattern is matched (substring) against the file's basename. Empty pattern disables the filter (show all). '!'-prefix means 'not matching any positive pattern' — the text after '!' is ignored."
        },
        "markdown-org.currentTag": {
          "type": "string",
          "default": "ALL",
          "description": "Currently selected tag filter for agenda view. Stored per workspace when a workspace is open."
        },
        "markdown-org.clockRoundMinutes": {
          "type": "number",
          "description": "Round CLOCK timestamps to specified minutes (e.g., 15, 30). Leave empty to disable rounding."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node ./out/test/suite/index.js",
    "test:integration": "npm run compile && node ./out/test/runTest.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "vsce package"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/glob": "^9.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.4.0",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
