# VS Code / extension host workspace state
.vscode/**
.vscode-test/**

# VCS / CI / tooling state
.git/**
.github/**
.claude/**
CLAUDE.md

# Sources and build artifacts
src/**
out/test/**
**/*.map
node_modules/**

# Test runtime artifacts -- coverage reports, husky hooks, c8 config,
# Mocha unit-test config, vscode-test CLI config, custom test runners.
coverage/**
.husky/**
.c8rc.json
.mocharc.unit.json
.vscode-test.mjs
.vscode-test.demo.mjs
scripts/**

# Linter / formatter / language config
.editorconfig
.eslintignore
.gitignore
.nvmrc
.prettierignore
.prettierrc.json
.vscodeignore
eslint.config.mjs
tsconfig.json

# npm lockfile — included via the published `package.json` already; shipping
# the lockfile inflates the VSIX without changing what the user installs.
package-lock.json

# Dev-only directories
docs/**
examples/**
test-workspace/**
test-workspace-demo*/**
temp/**

# Internal design / process notes that aren't user docs
# (most design docs live in docs/ now -- already excluded by docs/** above).
# DEVELOPMENT.md and TAG_FILTERING.md are referenced from README but
# Open VSX rewrites relative links to GitHub URLs, so shipping these
# files in the VSIX is dead weight.
TODO.md
DEVELOPMENT.md
TAG_FILTERING.md

# Claude Code repo-specific configuration (the .claude/** line above only
# catches the directory; this file lives at the repo root).
.claude-dir-settings.yaml

# Media: only the GIFs and PNGs referenced from README.md ship in
# the VSIX. The MP4 source files that the demo recording produces
# alongside each GIF aren't linked from anywhere user-visible.
# The SVG source of the icon is kept in-tree for future re-renders
# but only the resulting PNG is shipped.
media/*.mp4
media/*.svg

# Build outputs
*.vsix
